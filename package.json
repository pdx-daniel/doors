{
  "name": "doors",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "elysia": "1.4.18",
      "@elysiajs/cors": "1.4.0",
      "@elysiajs/eden": "1.4.5"
    }
  },
  "scripts": {
    "dev:server": "bun run --filter @doors/server dev",
    "dev:mobile": "bun run --filter @doors/mobile start",
    "dev:web": "bun run --filter @doors/mobile web",
    "ios": "bun run --filter @doors/mobile ios",
    "android": "bun run --filter @doors/mobile android",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe .",
    "ci": "biome ci .",
    "typecheck": "bun run --filter '*' typecheck",
    "basemap:refresh": "make basemap-refresh",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:migrate": "bun run --filter @doors/server db:migrate",
    "db:seed": "bun run --filter @doors/server db:seed",
    "db:reseed": "bun run --filter @doors/server db:reseed"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16"
  }
}
