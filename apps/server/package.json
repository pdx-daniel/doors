{
  "name": "@doors/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env run --watch src/index.ts",
    "start": "bun --env-file=../../.env run src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "bun --env-file=../../.env run scripts/migrate.ts",
    "db:seed": "bun --env-file=../../.env run scripts/seed.ts",
    "db:reset": "bun --env-file=../../.env run scripts/seed.ts"
  },
  "dependencies": {
    "@doors/api": "workspace:*",
    "@elysiajs/cors": "catalog:",
    "elysia": "catalog:",
    "postgres": "^3.4.7",
    "uuidv7": "^1.0.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.3"
  }
}
